<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ligue des Collègues - Paris 1N2</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-950 text-white min-h-screen">
    <nav class="bg-gray-800 p-4 shadow-lg border-b border-gray-700 flex justify-between items-center">
        <span class="text-xl font-black italic text-blue-400">🏆 LIGUE</span>
        <div class="flex items-center gap-4">
            <span class="text-sm">Salut, <strong><%= user.username %></strong></span>
            <a href="/logout" class="text-xs bg-red-900/50 hover:bg-red-800 px-3 py-1 rounded">Déconnexion</a>
        </div>
    </nav>

    <main class="max-w-4xl mx-auto p-6 space-y-10">
        <section class="bg-gray-900 p-8 rounded-3xl border border-gray-800 shadow-2xl">
            <h3 class="text-xl font-bold mb-8 flex items-center gap-3">⚽ Placer un pronostic 1N2</h3>
            
            <form action="/bet" method="POST" class="space-y-8">
                <div>
                    <label class="block text-xs uppercase text-gray-500 mb-2 font-bold">Choisir le match :</label>
                    <select name="matchId" id="matchSelect" class="w-full bg-gray-800 border border-gray-700 p-4 rounded-xl text-lg font-semibold" required>
    <option value="" data-f1="🏠" data-f2="🚀">-- Sélectionnez un match --</option>
    <% matches.forEach(match => { 
        // On sépare le nom pour extraire les drapeaux proprement
        const parts = match.teams.split(' - ');
        const f1 = (parts[0] ? Array.from(parts[0].trim())[0] : "🏠");
        const f2 = (parts[1] ? Array.from(parts[1].trim())[0] : "🚀");
    %>
        <option value="<%= match._id %>" data-f1="<%= f1 %>" data-f2="<%= f2 %>">
            <%= match.teams %>
        </option>
    <% }) %>
</select>
                </div>

                <div class="grid grid-cols-3 gap-6">
                    <label class="cursor-pointer group">
                        <input type="radio" name="prediction" value="1" class="hidden peer" required>
                        <div class="peer-checked:bg-blue-600 peer-checked:border-transparent bg-gray-800 border-2 border-gray-700 p-6 rounded-2xl text-center transition group-hover:bg-gray-700 h-full">
                            <span class="block text-6xl mb-4">🏠</span> <span class="text-base font-bold text-gray-300 peer-checked:text-white">Dom. (1)</span>
                        </div>
                    </label>

                    <label class="cursor-pointer group">
                        <input type="radio" name="prediction" value="N" class="hidden peer">
                        <div class="peer-checked:bg-gray-600 peer-checked:border-transparent bg-gray-800 border-2 border-gray-700 p-6 rounded-2xl text-center transition group-hover:bg-gray-700 h-full">
                            <span class="block text-6xl mb-4">🤝</span>
                            <span class="text-base font-bold text-gray-300 peer-checked:text-white">Nul (N)</span>
                        </div>
                    </label>

                    <label class="cursor-pointer group">
                        <input type="radio" name="prediction" value="2" class="hidden peer">
                        <div class="peer-checked:bg-blue-600 peer-checked:border-transparent bg-gray-800 border-2 border-gray-700 p-6 rounded-2xl text-center transition group-hover:bg-gray-700 h-full">
                            <span class="block text-6xl mb-4">🚀</span> <span class="text-base font-bold text-gray-300 peer-checked:text-white">Ext. (2)</span>
                        </div>
                    </label>
                </div>

                <button type="submit" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-black py-4 rounded-xl shadow-lg transition text-lg uppercase">Valider mon pari</button>
            </form>
        </section>

        <section>
            <h3 class="text-xl font-bold mb-6 px-2">Derniers Paris</h3>
            <div class="grid gap-5">
                <% bets.reverse().forEach(bet => { %>
                    <div class="bg-gray-800 border-l-4 border-blue-500 p-5 rounded-r-2xl flex justify-between items-center shadow-lg">
                        <div class="flex items-center gap-6">
                            <span class="text-sm font-bold bg-gray-700 text-gray-300 px-3 py-1 rounded-full"><%= bet.user %></span>
                            <div>
                                <p class="text-xs text-gray-500 uppercase font-bold"><%= bet.teams %></p>
                                <p class="text-lg"> Pronostic : 
                                    <span class="font-black text-blue-400">
                                        <%= bet.prediction === '1' ? 'Dom. (1)' : (bet.prediction === '2' ? 'Ext. (2)' : 'Nul (N)') %>
                                    </span>
                                </p>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        </section>
    </main>

    <script>
    const select = document.getElementById('matchSelect');
    const icons = document.querySelectorAll('.block.text-6xl');

    select.addEventListener('change', function() {
        // On récupère l'option qui vient d'être cliquée
        const selectedOption = this.options[this.selectedIndex];
        
        // On lit les drapeaux stockés dans "data-f1" et "data-f2"
        const flag1 = selectedOption.getAttribute('data-f1');
        const flag2 = selectedOption.getAttribute('data-f2');

        // On met à jour les cercles bleus
        if (icons.length >= 3) {
            icons[0].innerText = flag1;
            icons[2].innerText = flag2;
        }
    });
</script>
</body>
</html>