<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ligue des Collègues - Paris 1N2</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-950 text-white min-h-screen">
    <nav class="bg-gray-800 p-4 shadow-lg border-b border-gray-700 flex justify-between items-center">
        <span class="text-xl font-black italic text-blue-400">🏆 LIGUE</span>
        <div class="flex items-center gap-4">
            <span class="text-sm">Salut, <strong><%= user.username %></strong></span>
            <a href="/logout" class="text-xs bg-red-900/50 hover:bg-red-800 px-3 py-1 rounded">Déconnexion</a>
        </div>
    </nav>

    <main class="max-w-4xl mx-auto p-6 space-y-10">
        <section class="bg-gray-900 p-8 rounded-3xl border border-gray-800 shadow-2xl">
            <h3 class="text-xl font-bold mb-8 flex items-center gap-3">⚽ Placer un pronostic 1N2</h3>
            
            <form action="/bet" method="POST" class="space-y-8">
                <div>
                    <label class="block text-xs uppercase text-gray-500 mb-2 font-bold">Choisir le match :</label>
<select name="matchId" id="matchSelect" class="w-full bg-gray-800 border border-gray-700 p-4 rounded-xl font-semibold text-white" required>
    <option value="" data-c1="" data-c2="">-- Choisissez un match --</option>
    <% matches.forEach(match => { %>
        <option value="<%= match._id %>" data-c1="<%= match.code1 %>" data-c2="<%= match.code2 %>">
            <%= match.teams %>
        </option>
    <% }) %>
</select>
                </div>

                <div class="grid grid-cols-3 gap-6">
                    <label class="cursor-pointer group">
                        <input type="radio" name="prediction" value="1" class="hidden peer" required>
                        <div class="peer-checked:bg-blue-600 ... flex flex-col items-center">
							<img id="flagImg1" src="https://flagcdn.com/w80/un.png" class="w-16 h-12 object-cover mb-2 rounded shadow-md">
						</div>
                    </label>

                    <label class="cursor-pointer group">
                        <input type="radio" name="prediction" value="N" class="hidden peer">
                        <div class="peer-checked:bg-gray-600 peer-checked:border-transparent bg-gray-800 border-2 border-gray-700 p-6 rounded-2xl text-center transition group-hover:bg-gray-700 h-full">
                            <span class="block text-6xl mb-4">🤝</span>
                            <span class="text-base font-bold text-gray-300 peer-checked:text-white">Nul (N)</span>
                        </div>
                    </label>

                    <label class="cursor-pointer group">
                        <input type="radio" name="prediction" value="2" class="hidden peer">
                        <div class="peer-checked:bg-blue-600 ... flex flex-col items-center">
							<img id="flagImg2" src="https://flagcdn.com/w80/un.png" class="w-16 h-12 object-cover mb-2 rounded shadow-md">
						</div>
                    </label>
                </div>

                <button type="submit" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-black py-4 rounded-xl shadow-lg transition text-lg uppercase">Valider mon pari</button>
            </form>
        </section>

        <section class="mt-10">
    <div class="flex items-center justify-between mb-6 px-2">
        <h3 class="text-xl font-bold text-blue-400">🔒 Mes Pronostics Secrets</h3>
        <span class="text-xs bg-blue-900/30 text-blue-300 px-2 py-1 rounded-full border border-blue-800">Privé</span>
    </div>

    <div class="grid gap-4">
        <% if (bets.length > 0) { %>
            <% bets.forEach(bet => { %>
                <div class="bg-gray-900 border border-gray-800 p-5 rounded-2xl flex justify-between items-center shadow-xl hover:border-gray-700 transition">
                    <div class="flex items-center gap-5">
                        <div class="flex flex-col items-center bg-gray-800 p-2 rounded-lg w-16">
    <% if(bet.prediction === '1') { %>
        <% if (bet.code1) { %>
            <img src="https://flagcdn.com/w80/<%= bet.code1 %>.png" class="w-10 rounded shadow-sm mb-1">
        <% } else { %>
            <span class="text-xl mb-1">🏠</span>
        <% } %>
        <span class="text-[10px] font-bold text-gray-400">DOM.</span>
    <% } else if(bet.prediction === '2') { %>
        <% if (bet.code2) { %>
            <img src="https://flagcdn.com/w80/<%= bet.code2 %>.png" class="w-10 rounded shadow-sm mb-1">
        <% } else { %>
            <span class="text-xl mb-1">🚀</span>
        <% } %>
        <span class="text-[10px] font-bold text-gray-400">EXT.</span>
    <% } else { %>
        <span class="text-2xl mb-1">🤝</span>
        <span class="text-[10px] font-bold text-gray-400">NUL</span>
    <% } %>
</div>
                        
                        <div>
                            <p class="text-sm font-semibold text-gray-400 uppercase tracking-wider"><%= bet.teams %></p>
                            <p class="text-lg font-black text-white">
                                <%= bet.prediction === '1' ? 'Victoire Domicile' : (bet.prediction === '2' ? 'Victoire Extérieur' : 'Match Nul') %>
                            </p>
                        </div>
                    </div>

                    <button onclick="editBet('<%= bet._id %>', '<%= bet.matchId %>', '<%= bet.prediction %>')" 
                            class="flex items-center gap-2 bg-blue-600/10 hover:bg-blue-600 text-blue-400 hover:text-white text-xs font-bold px-4 py-2 rounded-xl border border-blue-500/20 transition-all">
                        <span>Modifier</span>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                        </svg>
                    </button>
                </div>
            <% }) %>
        <% } else { %>
            <div class="text-center py-10 bg-gray-900/50 rounded-3xl border border-dashed border-gray-800">
                <p class="text-gray-500">Aucun pari enregistré pour le moment.</p>
                <p class="text-xs text-gray-600 mt-1">Choisis un match ci-dessus pour commencer !</p>
            </div>
        <% } %>
    </div>
</section>
    </main>

    <script>
    const select = document.getElementById('matchSelect');
    const img1 = document.getElementById('flagImg1');
    const img2 = document.getElementById('flagImg2');

    select.addEventListener('change', function() {
        const opt = this.options[this.selectedIndex];
        const c1 = opt.getAttribute('data-c1');
        const c2 = opt.getAttribute('data-c2');

        // On change la source de l'image dynamiquement
        img1.src = c1 ? `https://flagcdn.com/w80/${c1}.png` : `https://flagcdn.com/w80/un.png`;
        img2.src = c2 ? `https://flagcdn.com/w80/${c2}.png` : `https://flagcdn.com/w80/un.png`;
    });
</script>
</body>
</html>