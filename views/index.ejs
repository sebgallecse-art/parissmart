<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tableau de bord - Paris</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-900 text-white min-h-screen">
    <nav class="bg-gray-800 p-4 shadow-lg flex justify-between items-center">
        <span class="text-xl font-bold italic text-blue-400">LIGUE DES COLLÈGUES</span>
        <div class="flex items-center gap-4">
            <span class="text-sm text-gray-300">Salut, <strong><%= user.username %></strong></span>
            <a href="/logout" class="text-xs bg-red-900/50 hover:bg-red-800 px-3 py-1 rounded border border-red-500">Déconnexion</a>
        </div>
    </nav>

    <main class="max-w-4xl mx-auto p-6">
	
        <section class="bg-gray-800 rounded-xl p-6 mb-8 border border-gray-700">
    <h3 class="text-lg font-semibold mb-6 flex items-center gap-2">⚽ Placer un pronostic</h3>
    
    <form action="/bet" method="POST" class="space-y-6">
        <div>
            <label class="block text-sm text-gray-400 mb-2">Choisir le match :</label>
            <select name="matchId" class="w-full bg-gray-900 border border-gray-600 p-3 rounded-lg outline-none focus:ring-2 focus:ring-blue-500" required>
                <% matches.forEach(match => { %>
                    <option value="<%= match._id %>"><%= match.teams %></option>
                <% }) %>
            </select>
        </div>

        <div class="grid grid-cols-3 gap-4">
            <label class="cursor-pointer group">
                <input type="radio" name="prediction" value="1" class="hidden peer" required>
                <div class="peer-checked:bg-blue-600 peer-checked:border-transparent bg-gray-900 border border-gray-600 p-4 rounded-xl text-center transition group-hover:bg-gray-700">
                    <span class="block text-2xl mb-1">🏠</span>
                    <span class="text-sm font-bold">Victoire 1</span>
                </div>
            </label>

            <label class="cursor-pointer group">
                <input type="radio" name="prediction" value="N" class="hidden peer">
                <div class="peer-checked:bg-gray-600 peer-checked:border-transparent bg-gray-900 border border-gray-600 p-4 rounded-xl text-center transition group-hover:bg-gray-700">
                    <span class="block text-2xl mb-1">🤝</span>
                    <span class="text-sm font-bold">Nul</span>
                </div>
            </label>

            <label class="cursor-pointer group">
                <input type="radio" name="prediction" value="2" class="hidden peer">
                <div class="peer-checked:bg-blue-600 peer-checked:border-transparent bg-gray-900 border border-gray-600 p-4 rounded-xl text-center transition group-hover:bg-gray-700">
                    <span class="block text-2xl mb-1">🚀</span>
                    <span class="text-sm font-bold">Victoire 2</span>
                </div>
            </label>
        </div>

        <button type="submit" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-3 rounded-xl shadow-lg transition">Valider mon pronostic</button>
    </form>
</section>

        <h3 class="text-xl font-bold mb-4 px-2">Paris en cours</h3>
        <div class="grid gap-4">
    <% bets.reverse().forEach(bet => { %>
        <div class="bg-gray-800 border-l-4 border-blue-500 p-4 rounded-r-xl flex justify-between items-center">
            <div>
                <p class="text-xs text-gray-400 uppercase font-bold"><%= bet.match %></p>
                <p class="text-lg"> Pronostic : 
                    <span class="font-bold text-blue-400">
                        <%= bet.prediction === '1' ? 'Équipe Domicile' : (bet.prediction === '2' ? 'Équipe Extérieur' : 'Match Nul') %>
                    </span>
                </p>
            </div>
            <div class="text-right">
                <span class="text-[10px] bg-gray-700 px-2 py-1 rounded text-gray-400"><%= bet.user %></span>
            </div>
        </div>
    <% }) %>
</div>
    </main>
</body>
</html>