<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Administration - Paris</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<section class="bg-gray-800 p-6 rounded-xl mb-8 border border-red-500/20">
    <h2 class="text-xl font-bold mb-4 text-red-400">🆕 Créer un Match</h2>
    <form action="/admin/match" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div class="flex gap-2">
        <input type="text" name="code1" placeholder="Code (ex: fr)" class="w-16 bg-gray-900 p-2 rounded border border-gray-600 text-center uppercase" maxlength="2">
        <input type="text" name="team1" placeholder="Équipe Domicile" class="flex-1 bg-gray-900 p-2 rounded border border-gray-600" required>
    </div>
    <div class="flex gap-2">
        <input type="text" name="code2" placeholder="Code (ex: de)" class="w-16 bg-gray-900 p-2 rounded border border-gray-600 text-center uppercase" maxlength="2">
        <input type="text" name="team2" placeholder="Équipe Extérieur" class="flex-1 bg-gray-900 p-2 rounded border border-gray-600" required>
    </div>
    <input type="datetime-local" name="date" class="bg-gray-900 p-2 rounded border border-gray-600 w-full" required>
    <button type="submit" class="bg-green-600 py-2 rounded font-black hover:bg-green-500 uppercase">Ajouter</button>
</form>
</section>
<body class="bg-gray-900 text-white p-8">
    <div class="max-w-4xl mx-auto">
        <div class="flex justify-between items-center mb-8">
            <h1 class="text-3xl font-bold text-red-500">Zone Admin 🔐</h1>
            <a href="/" class="text-blue-400 underline">Retour au site</a>
        </div>

        <div class="bg-gray-800 rounded-xl shadow-lg overflow-hidden">
            <table class="w-full text-left">
                <thead class="bg-gray-700 text-gray-300 uppercase text-sm">
                    <tr>
                        <th class="p-4">Joueur</th>
                        <th class="p-4">Match</th>
                        <th class="p-4">Pari</th>
                        <th class="p-4">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-700">
                    <% bets.forEach(bet => { %>
                        <tr class="hover:bg-gray-750">
                            <td class="p-4 font-semibold"><%= bet.user %></td>
                            <td class="p-4 text-gray-400"><%= bet.match %></td>
                            <td class="p-4 text-blue-400 font-mono text-lg"><%= bet.prediction %></td>
                            <td class="p-4">
                                <form action="/admin/delete/<%= bet._id %>" method="POST" onsubmit="return confirm('Supprimer ce pari ?')">
                                    <button class="text-red-500 hover:text-red-400 text-sm border border-red-500/30 px-2 py-1 rounded">Supprimer</button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
	<div class="bg-gray-900 p-6 rounded-3xl border border-gray-800 shadow-2xl">
    <h2 class="text-2xl font-bold text-white mb-6">Gestion des Matchs</h2>
    
    <div class="space-y-4">
        <% matches.forEach(match => { %>
            <div class="bg-gray-800 p-4 rounded-2xl flex flex-col md:flex-row justify-between items-center gap-4">
                <div class="flex items-center gap-3">
                    <img src="https://flagcdn.com/w40/<%= match.code1 %>.png" class="w-8">
                    <span class="text-white font-bold"><%= match.teams %></span>
                    <img src="https://flagcdn.com/w40/<%= match.code2 %>.png" class="w-8">
                </div>

                <div class="flex items-center gap-2">
                    <% if (!match.result) { %>
                        <span class="text-gray-400 text-sm mr-2">Saisir le résultat :</span>
                        <form action="/admin/match/result" method="POST" class="flex gap-2">
                            <input type="hidden" name="matchId" value="<%= match._id %>">
                            
                            <button name="result" value="1" class="bg-blue-600 hover:bg-blue-500 text-white px-3 py-1 rounded-lg text-sm font-bold">1</button>
                            <button name="result" value="N" class="bg-gray-600 hover:bg-gray-500 text-white px-3 py-1 rounded-lg text-sm font-bold">N</button>
                            <button name="result" value="2" class="bg-blue-600 hover:bg-blue-500 text-white px-3 py-1 rounded-lg text-sm font-bold">2</button>
                        </form>
                    <% } else { %>
                        <div class="flex items-center gap-2">
                            <span class="text-green-400 text-sm font-bold italic">Terminé : <%= match.result %></span>
                            <form action="/admin/match/result" method="POST">
                                <input type="hidden" name="matchId" value="<%= match._id %>">
                                <button name="result" value="" class="text-red-500 text-xs hover:underline">Modifier</button>
                            </form>
                        </div>
                    <% } %>

                    <form action="/admin/match/delete" method="POST" onsubmit="return confirm('Supprimer ce match ?')">
                        <input type="hidden" name="matchId" value="<%= match._id %>">
                        <button class="bg-red-900/30 text-red-500 p-2 rounded-lg hover:bg-red-900/50">
                            🗑️
                        </button>
                    </form>
                </div>
            </div>
        <% }) %>
    </div>
</div>
</body>
</html>