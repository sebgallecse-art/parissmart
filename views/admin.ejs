<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Administration - Paris</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-900 text-white p-8">
    <div class="max-w-4xl mx-auto">
        <div class="flex justify-between items-center mb-8">
            <h1 class="text-3xl font-bold text-red-500">Zone Admin 🔐</h1>
            <a href="/" class="text-blue-400 underline">Retour au site</a>
        </div>

        <div class="bg-gray-800 rounded-xl shadow-lg overflow-hidden">
            <table class="w-full text-left">
                <thead class="bg-gray-700 text-gray-300 uppercase text-sm">
                    <tr>
                        <th class="p-4">Joueur</th>
                        <th class="p-4">Match</th>
                        <th class="p-4">Pari</th>
                        <th class="p-4">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-700">
                    <% bets.forEach(bet => { %>
                        <tr class="hover:bg-gray-750">
                            <td class="p-4 font-semibold"><%= bet.user %></td>
                            <td class="p-4 text-gray-400"><%= bet.match %></td>
                            <td class="p-4 text-blue-400 font-mono text-lg"><%= bet.prediction %></td>
                            <td class="p-4">
                                <form action="/admin/delete/<%= bet._id %>" method="POST" onsubmit="return confirm('Supprimer ce pari ?')">
                                    <button class="text-red-500 hover:text-red-400 text-sm border border-red-500/30 px-2 py-1 rounded">Supprimer</button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>